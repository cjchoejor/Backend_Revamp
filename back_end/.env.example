DATABASE_URL="postgresql://postgres:postgres@localhost:5432/legphel_pms_dev?schema=public"

# --- Email (SMTP via Gmail) ---
# Required to send guest emails (S1..S9 lifecycle communications).
# To set up Gmail SMTP for the FROM address: enable 2FA on the Gmail account, then
# create an App Password under myaccount.google.com → Security → 2-Step Verification.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail@gmail.com
SMTP_PASS="16-char app password"
EMAIL_FROM="Hotel Name <your-gmail@gmail.com>"
# Optional. When unset, replies route back to SMTP_USER.
EMAIL_REPLY_TO=

# --- Email safety nets (testing phase) ---
# When set, ALL outbound emails are redirected to this address regardless of the guest's email
# on the entry. The original recipient is prepended to the subject as [→guest@example.com] so
# you can verify routing without spamming real guests. Unset for production.
EMAIL_REDIRECT_ALL_TO=

# Set to "true" to silently skip sending — handy for CI tests or local dev without SMTP.
EMAIL_DISABLE=
