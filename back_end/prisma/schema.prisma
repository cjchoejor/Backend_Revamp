model CommunicationRecord {
  id                        String               @id // readable PREFIX-YYYYMMDD-NNNN — allocated by allocateReadableId("COMMUNICATION", ...)
  entryId                   String?
  channel                   CommunicationChannel
  commType                  CommunicationType
  stageContext              Stage?
  direction                 String?              @default("OUTBOUND")
  messageId                 String?              @unique
  sendStatus                String?              @default("PENDING")
  acknowledgementStatus     String?              @default("PENDING")
  acknowledgementReceivedAt DateTime?
  acknowledgementTimeoutAt  DateTime?
  threadId                  String?
  inReplyToId               String?
  contentSummary            String?
  actorId                   String?
  payload                   Json?
  createdAt                 DateTime             @default(now())
  createdBy                 String

  entry     Entry?                @relation(fields: [entryId], references: [id])
  aiDrafts  AiDraftRecord[]
  decisions HumanDecisionRecord[]

  @@index([entryId, commType, channel])
  @@map("communication_records")
}

enum AiDraftStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

model AiDraftRecord {
  id                 String        @id @default(uuid())
  communicationId    String
  intentCategory     String
  confidenceScore    Float
  draftContent       String
  status             AiDraftStatus @default(PENDING_REVIEW)
  reviewTtlExpiresAt DateTime?
  createdAt          DateTime      @default(now())
  createdBy          String

  communication CommunicationRecord   @relation(fields: [communicationId], references: [id], onUpdate: Cascade)
  decisions     HumanDecisionRecord[]

  @@index([communicationId])
  @@index([status, reviewTtlExpiresAt])
  @@map("ai_draft_records")
}

enum HumanDecisionType {
  APPROVE
  REJECT
  ESCALATE
}

model HumanDecisionRecord {
  id              String            @id @default(uuid())
  aiDraftId       String?
  communicationId String?
  decisionType    HumanDecisionType
  decisionReason  String?
  decidedAt       DateTime          @default(now())
  decidedBy       String
  createdAt       DateTime          @default(now())
  createdBy       String

  aiDraft       AiDraftRecord?       @relation(fields: [aiDraftId], references: [id])
  communication CommunicationRecord? @relation(fields: [communicationId], references: [id], onUpdate: Cascade)

  @@index([aiDraftId])
  @@index([communicationId])
  @@map("human_decision_records")
}

// --- Travel agents, corporate accounts, rate cards (Phase B) -------------

/** Mode-of-contact for agent/corporate primary contact. */
enum ContactMode {
  PHONE
  EMAIL
  WHATSAPP
  IN_PERSON
  OTHER
}

/** Discriminator for which kind of party a RateCard belongs to. */
enum PartyType {
  TRAVEL_AGENT
  CORPORATE
}

/**
 * Meal plan options carried on a RateCard. Mirrors the legacy `agent_rate` columns:
 *   CP         = breakfast included
 *   MAP_LUNCH  = breakfast + lunch
 *   MAP_DINNER = breakfast + dinner
 *   AP         = breakfast + lunch + dinner
 * Standalone breakfast/lunch/dinner add-on rates live as separate fields on RateCard,
 * not as MealPlanType values.
 */
enum MealPlanType {
  CP
  MAP_LUNCH
  MAP_DINNER
  AP
}

/**
 * TravelAgent — a third-party booking agent the hotel works with. Tracked by
 * EntityVersionSnapshot; commission rate (if any) lives on the operational AgentProfile
 * row at the time of booking, not here. This table carries agent identity + their
 * negotiated rate card.
 */
model TravelAgent {
  id              String       @id // readable TA-YYYYMMDD-NNNN
  displayName     String
  contactNumber   String?
  contactEmail    String?
  modeOfContact   ContactMode  @default(PHONE)
  notes           String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  createdBy       String
  updatedAt       DateTime     @updatedAt

  inquiries       Inquiry[]

  @@index([displayName])
  @@index([isActive])
  @@map("travel_agents")
}

/**
 * CorporateAccount — a company / institutional account with negotiated rates.
 * Distinct from TravelAgent because corporates carry tax + billing fields and don't
 * carry commission. Tracked by EntityVersionSnapshot.
 */
model CorporateAccount {
  id              String       @id // readable CORP-YYYYMMDD-NNNN
  displayName     String
  contactNumber   String?
  contactEmail    String?
  modeOfContact   ContactMode  @default(EMAIL)
  gstNumber       String?
  billingAddress  String?
  notes           String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  createdBy       String
  updatedAt       DateTime     @updatedAt

  inquiries       Inquiry[]

  @@index([displayName])
  @@index([isActive])
  @@map("corporate_accounts")
}

/**
 * RateCard — the rates an agent / corporate has negotiated with the hotel. Append-only
 * versioned, same pattern as ConfigurationEntry: editing creates a new row with a new
 * effectiveFrom and closes the prior with effectiveTo. Historical bookings always look up
 * the rate card that was active at the time they were quoted.
 *
 * `partyType` + `partyId` is a polymorphic reference; no Prisma FK constraint. The admin
 * service validates the referenced party exists on every write.
 */
model RateCard {
  id                String       @id // readable RC-YYYYMMDD-NNNN
  partyType         PartyType
  partyId           String       // FK to TravelAgent.id OR CorporateAccount.id depending on partyType
  // Base + extras
  roomBaseRate      Decimal      @db.Decimal(10, 2)
  extraBedRate      Decimal?     @db.Decimal(10, 2)
  cnbPercent        Int?         // 0-100 — child-no-bed discount percentage
  // Standalone meal add-on rates (à la carte)
  breakfastRate     Decimal?     @db.Decimal(10, 2)
  lunchRate         Decimal?     @db.Decimal(10, 2)
  dinnerRate        Decimal?     @db.Decimal(10, 2)
  // Meal-plan-inclusive rates
  cpRate            Decimal?     @db.Decimal(10, 2)
  mapLunchRate      Decimal?     @db.Decimal(10, 2)
  mapDinnerRate     Decimal?     @db.Decimal(10, 2)
  apRate            Decimal?     @db.Decimal(10, 2)
  currency          String       @default("BTN")
  effectiveFrom     DateTime     @default(now())
  effectiveTo       DateTime?    // null = currently active
  notes             String?
  createdAt         DateTime     @default(now())
  createdBy         String

  overrides         RoomTypeRateOverride[]

  @@index([partyType, partyId, effectiveFrom])
  @@index([effectiveTo])
  @@map("rate_cards")
}

/**
 * RoomTypeRateOverride — optional override of `RateCard.roomBaseRate` for a specific
 * RoomType. Tied to a specific RateCard version; when the admin creates a new RateCard
 * version, the service copies the active overrides forward.
 */
model RoomTypeRateOverride {
  id              String   @id @default(uuid())
  rateCardId      String
  roomTypeId      String
  roomBaseRate    Decimal  @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime @default(now())
  createdBy       String

  rateCard        RateCard @relation(fields: [rateCardId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  roomType        RoomType @relation(fields: [roomTypeId], references: [id], onUpdate: Cascade)

  @@unique([rateCardId, roomTypeId])
  @@index([roomTypeId])
  @@map("room_type_rate_overrides")
}

// --- Readable business IDs (PREFIX-YYYYMMDD-####, daily sequence) --------

model ReadableIdSequence {
  prefix       String
  sequenceDate String @map("sequence_date")
  lastValue    Int    @default(0) @map("last_value")

  @@id([prefix, sequenceDate])
  @@map("readable_id_sequences")
}
