// --- Admin console (ACIG v1.1 core models) ------------------------------

/**
 * EntityVersionSnapshot — generic version-history table for in-place CRUD admin tables
 * (HotelProfile, Department, Role, StaffUser, RatePlanRegistry, SeasonCalendar, PackageRegistry,
 * CancellationPolicyRegistry, ModeConfiguration, CommunicationTemplate, InvoiceTemplate,
 * FeedbackSurveyTemplate, HandoffChecklistTemplate, WorkOrderTemplate, VipNotificationRoutingConfig).
 *
 * Before every UPDATE through an admin endpoint that opts in (via `withEntityVersionSnapshot`),
 * the prior row state is captured here as `rowJson`. Restoring a snapshot writes its JSON back
 * to the live row and creates another snapshot capturing what was just superseded.
 *
 * Snapshots are kept forever (compliance + audit). Only L4 may write or restore.
 */
model EntityVersionSnapshot {
  id          String   @id @default(uuid())
  entityType  String   // e.g. "HotelProfile", "Department"
  entityId    String
  version     Int      // per-entity sequence, starts at 1
  rowJson     Json     // the full row state BEFORE the change this snapshot precedes
  changedBy   String
  changedAt   DateTime @default(now())
  changeNote  String?  // optional reason / "why" text from the admin

  @@unique([entityType, entityId, version])
  @@index([entityType, entityId])
  @@index([changedAt])
  @@map("entity_version_snapshots")
}

enum ModeLifecycleState {
  DRAFT
  VALIDATED
  ACTIVE
  SUPERSEDED
}

// --- Configuration ------------------------------------------------------

// SIG-S1 §2.12 — ConfigurationEntry with date-range semantics. Admin writes only.
model ConfigurationEntry {
  id            String    @id @default(uuid())
  configKey     String
  configValue   Json
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  setBy         String    @default("actor-seed-system")
  setAt         DateTime  @default(now())
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([configKey, effectiveFrom])
  @@map("configuration_entries")
}

model HotelProfile {
  id                    String   @id @default(uuid())
  hotelName             String
  registeredAddress     String
  tradingAddress        String?
  contactNumbers        Json
  primaryEmail          String
  operatingHours        Json
  publicHolidaySchedule Json
  timeZone              String
  propertyCurrency      String
  version               Int      @default(1)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  createdBy             String

  @@map("hotel_profile")
}

model Department {
  id             String   @id @default(uuid())
  departmentCode String   @unique
  departmentName String
  isActive       Boolean  @default(true)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String

  @@map("departments")
}

model Role {
  id          String     @id @default(uuid())
  roleCode    String     @unique
  displayName String
  actorLevel  ActorLevel
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   String

  permissions RolePermissionMapping[]
  sessionCfg  RoleSessionConfig?

  @@map("roles")
}

model RolePermissionMapping {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  isAllowed    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String

  role Role @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permission_mappings")
}

model RoleSessionConfig {
  id                       String   @id @default(uuid())
  roleId                   String   @unique
  idleLockTimeoutSeconds   Int
  hardLogoutTimeoutSeconds Int
  manualLockAvailable      Boolean  @default(true)
  version                  Int      @default(1)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  createdBy                String

  role Role @relation(fields: [roleId], references: [id])

  @@map("role_session_configs")
}

model PolicyRegistry {
  id               String   @id @default(uuid())
  policyId         String
  policyClass      String
  policyDefinition Json
  version          Int      @default(1)
  effectiveFrom    DateTime @default(now())
  isActive         Boolean  @default(true)
  createdBy        String
  createdAt        DateTime @default(now())

  @@unique([policyId, version])
  @@map("policy_registry")
}

// ACIG §2.1A.7 — operational scenario definitions (New Booking, Room Change, …).
// `stageRoute`, `autoFulfilmentConditions`, `featureDependencies` are the spec's three typed
// JSON columns. `displayName` keeps its pragmatic name (spec calls it `modeName`).
model ModeConfiguration {
  id                       String             @id @default(uuid())
  modeKey                  String
  displayName              String
  description              String?
  lifecycleState           ModeLifecycleState @default(DRAFT)
  isActive                 Boolean            @default(false)
  isPredefined             Boolean            @default(false)
  stageRoute               Json               @default("[]")
  autoFulfilmentConditions Json               @default("[]")
  featureDependencies      Json               @default("[]")
  version                  Int                @default(1)
  effectiveFrom            DateTime           @default(now())
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  createdBy                String

  @@unique([modeKey, version])
  @@index([modeKey])
  @@map("mode_configurations")
}

model CommunicationTemplate {
  id              String   @id @default(uuid())
  templateKey     String   @unique
  channel         String
  stage           Stage?
  templateType    String
  subjectTemplate String?
  bodyTemplate    String
  isActive        Boolean  @default(true)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String

  @@map("communication_templates")
}

model InvoiceTemplate {
  id           String      @id @default(uuid())
  templateKey  String      @unique
  invoiceType  InvoiceType
  title        String
  bodyTemplate String
  isActive     Boolean     @default(true)
  version      Int         @default(1)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  createdBy    String

  @@map("invoice_templates")
}

model FeedbackSurveyTemplate {
  id          String   @id @default(uuid())
  templateKey String   @unique
  title       String
  questions   Json
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String

  @@map("feedback_survey_templates")
}

model VipNotificationRoutingConfig {
  id             String   @id @default(uuid())
  vipTier        String
  notifyRoles    Json
  notifyActorIds Json
  isActive       Boolean  @default(true)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String

  @@index([vipTier])
  @@map("vip_notification_routing_configs")
}

model HandoffChecklistTemplate {
  id             String      @id @default(uuid())
  handoffType    HandoffType
  version        Int         @default(1)
  checklistItems Json
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  createdBy      String

  @@unique([handoffType, version])
  @@map("handoff_checklist_templates")
}

model WorkOrderTemplate {
  id          String        @id @default(uuid())
  templateKey String        @unique
  useType     EntryUseType?
  title       String
  todoItems   Json
  isActive    Boolean       @default(true)
  version     Int           @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdBy   String

  @@map("work_order_templates")
}

// --- Admin console (ACIG v1.1 registry models) -------------------------

// ACIG §6.2.8 RatePlanService. overrideMargin = override_margin_per_rate_plan.
// Walk-in designation is held in ConfigurationEntry key `availability.walkIn.ratePlanId`.
// SIG-S2 §5.1 — PricingPipelineEngine reads `type` for priority resolution and `msr` (minimum
// sell rate) as the floor that discount + override paths may not cross.
model RatePlanRegistry {
  id             String   @id @default(uuid())
  name           String   @unique
  description    String?
  roomTypeId     String?
  type           String   @default("INDIVIDUAL") // INDIVIDUAL | PROMOTIONAL | TIER | CHANNEL | RACK
  baseRate       Decimal  @db.Decimal(15, 2)
  currency       String   @default("BTN")
  msr            Decimal? @db.Decimal(15, 2)
  overrideMargin Decimal? @db.Decimal(5, 4)
  isActive       Boolean  @default(true)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String

  @@map("rate_plan_registry")
}

// ACIG §6.2.9 SeasonService. Active seasons may not overlap (service-validated).
model SeasonCalendar {
  id             String   @id @default(uuid())
  name           String   @unique
  startDate      DateTime
  endDate        DateTime
  rateMultiplier Decimal? @db.Decimal(6, 4)
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String

  @@map("season_calendar")
}

// ACIG §6.2.10 PackageService.
model PackageRegistry {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  inclusions      Json
  priceAdjustment Decimal? @db.Decimal(15, 2)
  currency        String   @default("BTN")
  isActive        Boolean  @default(true)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String

  @@map("package_registry")
}

// ACIG §6.2.12 / §2.2.2 CancellationPolicyService.
model CancellationPolicyRegistry {
  id              String   @id @default(uuid())
  name            String   @unique
  penaltyTiers    Json // array of { daysBeforeArrival, penaltyPercentage }
  noShowTreatment String
  isActive        Boolean  @default(true)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String

  @@map("cancellation_policy_registry")
}

// ACIG §2.1A.6 — single-row AI actor identity. actorType fixed to SYSTEM.
model AiActorIdentity {
  id          String     @id @default(uuid())
  displayName String
  actorType   ActorLevel @default(SYSTEM)
  isActive    Boolean    @default(true)
  version     Int        @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   String

  @@map("ai_actor_identity")
}

// --- Staff & Sessions (SIG-S1 §6.6 SessionService / Policy 69) ---------

model StaffUser {
  id                         String     @id @default(uuid())
  fullName                   String
  email                      String?    @unique
  actorLevel                 ActorLevel
  pinHash                    String
  role                       String
  idleThresholdSeconds       Int        @default(600)
  hardLogoutThresholdSeconds Int        @default(28800)
  isActive                   Boolean    @default(true)
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt

  sessions SessionRecord[]

  @@map("staff_users")
}

model SessionRecord {
  id               String        @id @default(uuid())
  userId           String
  terminalId       String
  status           SessionStatus @default(ACTIVE)
  authenticatedAt  DateTime      @default(now())
  idleLockedAt     DateTime?
  manuallyLockedAt DateTime?
  hardLoggedOutAt  DateTime?
  lastActiveAt     DateTime      @default(now())
  jwtToken         String?       @db.Text
  createdAt        DateTime      @default(now())

  user   StaffUser            @relation(fields: [userId], references: [id])
  events SessionEventRecord[]

  @@index([userId, status])
  @@map("session_records")
}

model SessionEventRecord {
  id              String           @id @default(uuid())
  sessionId       String
  eventType       SessionEventType
  outgoingActorId String?
  incomingActorId String?
  terminalId      String
  occurredAt      DateTime         @default(now())

  session SessionRecord @relation(fields: [sessionId], references: [id])

  @@index([sessionId, eventType])
  @@map("session_event_records")
}

// --- Guest Profiles -----------------------------------------------------

model GuestProfile {
  id                       String    @id @default(uuid())
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  nationality              String?
  vipTier                  String?
  clientTier               String?   @default("STANDARD")
  preferences              Json?
  behaviouralFlags         Json?
  observationQueue         Json?
  stayHistorySummary       Json?
  isActive                 Boolean   @default(true)
  identityVerifiedAt       DateTime?
  identityVerifiedBy       String?
  identityVerificationPath String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  createdBy                String    @default("actor-seed-system")

  entries                 Entry[]
  identityDocuments       GuestIdentityDocument[]
  vipArrivalNotifications VIPArrivalNotificationEvent[]
  inquiries               Inquiry[]

  @@map("guest_profiles")
}

model GuestIdentityDocument {
  id                 String    @id @default(uuid())
  guestProfileId     String
  documentType       String
  documentNumber     String
  issuingCountry     String?
  expiryDate         DateTime?
  capturedAt         DateTime
  capturedBy         String
  retentionPeriod    Int
  retentionExpiresAt DateTime
  createdAt          DateTime  @default(now())

  guestProfile GuestProfile @relation(fields: [guestProfileId], references: [id])

  @@map("guest_identity_documents")
}

model VIPArrivalNotificationEvent {
  id                       String   @id @default(uuid())
  entryId                  String
  guestProfileId           String
  roomNumber               String
  vipTier                  String
  preferences              Json?
  specialNotes             String?
  checkInInitiatedAt       DateTime
  recipientRoles           Json
  notificationDispatchedAt DateTime @default(now())
  createdAt                DateTime @default(now())
  createdBy                String

  entry        Entry        @relation(fields: [entryId], references: [id])
  guestProfile GuestProfile @relation(fields: [guestProfileId], references: [id])

  @@map("vip_arrival_notification_events")
}

// --- Inquiry & Entry ----------------------------------------------------

model Inquiry {
  id                         String    @id @default(uuid())
  referenceNumber            String    @unique
  guestProfileId             String
  agentProfileId             String?
  sourceChannel              String    @default("DIRECT")
  defaultCustodianId         String
  notes                      String?
  /// SIG-S1 corporate/government context (required for CORP/GOV at S1→S2 exit)
  corporateClientRef         String?
  corporateCoordinator       String?
  corporateContextCapturedAt DateTime?
  corporateContextCapturedBy String?
  /// Phase B/C — link to a Phase-B TravelAgent or CorporateAccount. At most ONE of these two
  /// is set per inquiry; the booking inherits that party's negotiated RateCard at quotation.
  /// The legacy `agentProfileId` and `corporateClientRef` fields stay for backward compat with
  /// pre-Phase-B data; new intake forms write to these two FKs.
  travelAgentId              String?
  corporateAccountId         String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  createdBy                  String    @default("actor-seed-system")
  parkedAt                   DateTime?
  parkedBy                   String?

  entries        Entry[]
  duplicateFlags DuplicateDetectionFlag[]
  guestProfile   GuestProfile             @relation(fields: [guestProfileId], references: [id])
  agentProfile   AgentProfile?            @relation(fields: [agentProfileId], references: [id])
  travelAgent      TravelAgent?           @relation(fields: [travelAgentId], references: [id], onUpdate: Cascade)
  corporateAccount CorporateAccount?      @relation(fields: [corporateAccountId], references: [id], onUpdate: Cascade)

  @@index([guestProfileId])
  @@index([travelAgentId])
  @@index([corporateAccountId])
  @@map("inquiries")
}

enum DuplicateFlagStatus {
  OPEN
  RESOLVED
}

enum DuplicateResolutionType {
  MERGE
  ACKNOWLEDGE
  DISMISS
}

model DuplicateDetectionFlag {
  id                  String                   @id @default(uuid())
  inquiryId           String
  status              DuplicateFlagStatus      @default(OPEN)
  resolutionType      DuplicateResolutionType?
  resolutionReason    String?
  mergedIntoInquiryId String?
  createdAt           DateTime                 @default(now())
  createdBy           String
  resolvedAt          DateTime?
  resolvedBy          String?

  inquiry Inquiry @relation(fields: [inquiryId], references: [id])

  @@index([inquiryId, status])
  @@map("duplicate_detection_flags")
}

model Entry {
  id                 String            @id @default(uuid())
  inquiryId          String
  guestProfileId     String?
  segmentNumber      Int               @default(1)
  useType            EntryUseType      @default(LEISURE)
  status             EntryStatus       @default(ACTIVE)
  currentStage       Stage             @default(S1)
  /// SIG-S6 — walk-in compressed flow indicator (no prior reservations/H1).
  walkInCompressed   Boolean           @default(false)
  checkInDate        DateTime?
  checkOutDate       DateTime?
  guestCount         Int?
  /// Breakdown of the head count. guestCount remains the canonical total (adultCount + childCount when both set).
  /// adultCount/childCount are nullable for backward compatibility with pre-Phase-D inquiries.
  adultCount         Int?
  childCount         Int?
  /// Ages of accompanying children, ordered. Length should equal childCount; not enforced at the DB layer.
  childAges          Int[]             @default([])
  otaSource          Boolean           @default(false)
  otaReference       String?
  groupBillingMode   GroupBillingMode?
  parkedAt           DateTime?
  parkedBy           String?
  parkedIndividually Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdBy          String
  version            Int               @default(1)
  closedAt           DateTime?
  closedBy           String?

  /// Simulates W5 no-show cutoff having fired (normally set by worker).
  noShowCutoffReachedAt DateTime?

  /// When credit ceiling Tier 2 applies, FOM must acknowledge before S5→S6.
  creditCeilingTier2AcknowledgedAt DateTime?
  creditCeilingTier2AcknowledgedBy String?

  /// AWAITING_WRITTEN_CONFIRMATION sub-state blocks normal S5→S6 exit.
  awaitingWrittenConfirmationActive Boolean @default(false)

  /// Message-ID of the FIRST email sent for this entry's journey. Used by the email service to
  /// anchor every later email (PI, confirmation, pre-arrival, invoice, feedback) into the same
  /// Gmail thread via In-Reply-To / References headers. Null until the first email is sent.
  emailThreadRootMessageId String?

  /// SIG-S6 — key issuance recorded at check-in completion.
  keysIssuedAt    DateTime?
  keysIssuedCount Int?
  keysIssuedBy    String?

  /// SIG-S6 — registration snapshot at check-in completion.
  registrationCompletedAt DateTime?
  registrationCompletedBy String?

  /// SIG-S1 apartment context (required for APARTMENT at S1→S2 exit)
  apartmentDurationNights Int?
  apartmentRateTierCode   String?

  inquiry                 Inquiry                       @relation(fields: [inquiryId], references: [id])
  guestProfile            GuestProfile?                 @relation(fields: [guestProfileId], references: [id])
  segments                Segment[]
  // SIG-S4 §90/§197: Reservations are per-segment immutable history. `reservation` points at the
  // CURRENT (latest-confirmed) Reservation via currentReservationId so existing one-to-one reads are
  // unchanged; `reservations` is the append-only per-segment history (prior confirmations, read-only).
  currentReservationId    String?                       @unique
  reservation             Reservation?                  @relation("EntryCurrentReservation", fields: [currentReservationId], references: [id])
  reservations            Reservation[]                 @relation("EntryReservations")
  folio                   Folio?
  committedHold           CommittedHold?
  handoffs                HandoffRecord[]
  preArrivalTasks         PreArrivalTask[]
  roomAssignments         RoomAssignment[]
  noShowDetermination     NoShowDeterminationRecord?
  stageDwellRecords       StageDwellRecord[]
  availabilityConfigs     AvailabilityConfiguration[]
  processingLocks         ProcessingLockRecord[]
  traceEvents             TraceEvent[]
  spaceAllocations        SpaceAllocation[]
  quotations              Quotation[]
  speculativeHolds        SpeculativeHold[]
  cancellationDisclosure  CancellationDisclosureRecord?
  vipArrivalNotifications VIPArrivalNotificationEvent[]
  disputes                DisputeRecord[]
  amendmentEventRecords   AmendmentEventRecord[]
  roomInspectionRecords   RoomInspectionRecord[]
  keyReturnRecords        KeyReturnRecord[]
  invoices                Invoice[]
  timers                  TimerRecord[]
  writeOffRecords         WriteOffRecord[]
  followUpTasks           FollowUpTaskRecord[]
  communications          CommunicationRecord[]
  equipmentAllocations    EquipmentAllocation[]
  commissionDueRecords    CommissionDueRecord[]

  @@index([inquiryId])
  @@index([currentStage, status])
  @@map("entries")
}

// --- S9: Agent commissions ------------------------------------------------

model AgentProfile {
  id                      String           @id @default(uuid())
  displayName             String
  commissionRate          Decimal?         @db.Decimal(5, 4)
  commissionBasis         CommissionBasis? // optional; if missing while rate exists => RATE_MISSING path
  commissionEffectiveFrom DateTime? // ACIG §6.2.22 — admin-set via PostStayAndGovernanceService
  createdAt               DateTime         @default(now())
  createdBy               String

  inquiries      Inquiry[]
  commissionDues CommissionDueRecord[]

  @@map("agent_profiles")
}

enum CommissionBasis {
  NET_ROOM_RATE
  GROSS_ROOM_RATE
  TOTAL_FOLIO
}

enum CommissionDueStatus {
  PENDING
  RATE_MISSING
  SETTLED
}

model CommissionDueRecord {
  id               String              @id // readable PREFIX-YYYYMMDD-NNNN — allocated by allocateReadableId("COMMISSION_DUE", ...)
  entryId          String
  agentProfileId   String
  commissionRate   Decimal             @db.Decimal(5, 4)
  commissionBasis  CommissionBasis?
  calculatedAmount Decimal?            @db.Decimal(15, 2)
  currency         String              @default("BTN")
  status           CommissionDueStatus @default(PENDING)
  createdAt        DateTime            @default(now())
  createdBy        String

  entry        Entry        @relation(fields: [entryId], references: [id])
  agentProfile AgentProfile @relation(fields: [agentProfileId], references: [id])

  @@index([entryId])
  @@index([agentProfileId])
  @@map("commission_due_records")
}

// --- S9: Catering equipment return ---------------------------------------

model EquipmentAllocation {
  id                String    @id @default(uuid())
  entryId           String
  equipmentCode     String
  allocatedAt       DateTime  @default(now())
  allocatedBy       String
  returnDeadlineAt  DateTime
  returnConfirmedAt DateTime?
  returnConfirmedBy String?
  createdAt         DateTime  @default(now())

  entry Entry @relation(fields: [entryId], references: [id])

  @@index([entryId])
  @@map("equipment_allocations")
}

model Segment {
  id            String    @id @default(uuid())
  entryId       String
  segmentNumber Int
  stage         Stage     @default(S1)
  startedAt     DateTime  @default(now())
  sealedAt      DateTime?
  sealedBy      String?
  notes         String?
  createdBy     String    @default("actor-seed-system")

  entry Entry @relation(fields: [entryId], references: [id])

  amendmentEventRecords   AmendmentEventRecord[]
  quotations              Quotation[]
  speculativeHolds        SpeculativeHold[]
  billingModelTransitions BillingModelTransitionRecord[]

  @@unique([entryId, segmentNumber])
  @@map("segments")
}

// --- S1 primary artefacts ----------------------------------------------

model AvailabilityConfiguration {
  id                        String    @id @default(uuid())
  entryId                   String
  segmentId                 String?
  searchCriteria            Json
  resultSet                 Json
  optionSelected            Json?
  isStale                   Boolean   @default(false)
  stalenessAt               DateTime?
  deficientAcknowledgements Json?
  sealedAt                  DateTime?
  createdAt                 DateTime  @default(now())
  createdBy                 String

  entry Entry @relation(fields: [entryId], references: [id])

  @@index([entryId, segmentId])
  @@map("availability_configurations")
}

enum ProcessingLockStatus {
  ACTIVE
  EXPIRED
  RELEASED
}

model ProcessingLockRecord {
  id                 String               @id @default(uuid())
  actorId            String
  channel            String
  inventoryReference String
  entryId            String?
  segmentId          String?
  placedAt           DateTime             @default(now())
  ttlSeconds         Int
  expiresAt          DateTime
  status             ProcessingLockStatus @default(ACTIVE)
  expiredAt          DateTime?
  releasedAt         DateTime?
  revalidationCount  Int                  @default(0)
  pgBossJobId        String?
  createdAt          DateTime             @default(now())

  entry              Entry?                    @relation(fields: [entryId], references: [id])
  revalidationDeltas RevalidationDeltaRecord[]

  @@index([inventoryReference, status])
  @@index([status, expiresAt])
  @@map("processing_lock_records")
}

model RevalidationDeltaRecord {
  id                     String   @id @default(uuid())
  processingLockId       String
  availabilityChanged    Boolean  @default(false)
  deficientStatusChanged Boolean  @default(false)
  pricingChanged         Boolean  @default(false)
  availabilityDelta      Json?
  deficientDelta         Json?
  pricingDelta           Json?
  createdAt              DateTime @default(now())
  createdBy              String

  processingLock ProcessingLockRecord @relation(fields: [processingLockId], references: [id])

  @@map("revalidation_delta_records")
}

// --- Trace events (append-only, free-form event type per SIG §2.11) -----

model TraceEvent {
  id             String     @id @default(uuid())
  eventType      String
  actorId        String     @default("actor-seed-system")
  actorLevel     ActorLevel @default(L1)
  entityType     String     @default("Entry")
  entityId       String     @default("")
  operation      String     @default("UPDATE")
  payload        Json       @default("{}")
  timestamp      DateTime   @default(now())
  stageContext   Stage?
  segmentContext String?
  correlationId  String?
  inquiryId      String?
  entryId        String?
  createdAt      DateTime   @default(now())
  createdBy      String     @default("actor-seed-system")

  entry Entry? @relation(fields: [entryId], references: [id])

  @@index([entityType, entityId])
  @@index([correlationId])
  @@index([actorId])
  @@index([timestamp])
  @@index([inquiryId])
  @@index([entryId, eventType])
  @@map("trace_events")
}

// --- Spaces & Allocations ---------------------------------------------

model Space {
  id                    String   @id @default(uuid())
  code                  String   @unique
  name                  String
  spaceType             String   @default("HALL")
  defaultCapacity       Int      @default(0)
  capacity              Int      @default(0)
  seatingConfigurations Json     @default("[]")
  expansionLinks        Json?
  isAvailable           Boolean  @default(true)
  isEventInProgress     Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt

  allocations      SpaceAllocation[]
  speculativeHolds SpeculativeHold[]

  @@map("spaces")
}

enum SpaceAllocationState {
  QUOTED
  HELD
  CONFIRMED
  RELEASED
}

model SpaceAllocation {
  id         String               @id @default(uuid())
  spaceId    String
  entryId    String
  segmentId  String?
  state      SpaceAllocationState @default(QUOTED)
  eventBlock Json
  createdAt  DateTime             @default(now())
  createdBy  String

  space Space @relation(fields: [spaceId], references: [id])
  entry Entry @relation(fields: [entryId], references: [id])

  @@index([spaceId, state])
  @@map("space_allocations")
}

// --- Room inventory (Model 1 + Model 2) --------------------------------

model RoomType {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  /// Total guests allowed in a room of this type (adults + children, infants may be excluded
  /// per the child policy). Defaults match the legacy Room.capacity of 2 so existing rows
  /// continue to behave the same way.
  maxOccupancy              Int @default(2)
  /// Max children allowed in a room of this type — independent cap on top of maxOccupancy.
  maxChildren               Int @default(2)
  /// Minimum number of accompanying adults required for any children to occupy this room type.
  /// 1 = "at least one adult must be present with the children".
  requiredAccompanyingAdults Int @default(1)
  /// Max extra beds available for a room of this type (0 = no extra bed possible).
  maxExtraBeds              Int @default(0)

  rooms             Room[]
  committedHolds    CommittedHold[]
  rateOverrides     RoomTypeRateOverride[]

  @@map("room_types")
}

model Room {
  id                String              @id @default(uuid())
  roomNumber        String              @unique
  roomTypeId        String
  floorNumber       Int?
  capacity          Int                 @default(2)
  currentClaimState InventoryClaimState @default(FREE)
  physicalState     RoomPhysicalState   @default(AVAILABLE_CLEAN)
  expectedReadyAt   DateTime?
  /// SIG-S1 shadow inventory surface for Policy 14 filtering at availability query time.
  isShadowInventory Boolean             @default(false)

  // Model 2 — Physical state fields per SIG §2.6
  isDeficient                Boolean                     @default(false)
  deficientConditionCategory DeficientConditionCategory?
  deficientSince             DateTime?
  deficientDeadline          DateTime?
  isUnderMaintenance         Boolean                     @default(false)
  maintenanceDeadline        DateTime?
  cleansingRitualCompleted   Boolean                     @default(false)
  isBlocked                  Boolean                     @default(false)
  blockedReason              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roomType                  RoomType                   @relation(fields: [roomTypeId], references: [id])
  deficientConditionRecords DeficientConditionRecord[]
  speculativeHolds          SpeculativeHold[]
  roomAssignments           RoomAssignment[]
  claimStateEvents          RoomClaimStateEvent[]
  roomInspectionRecords     RoomInspectionRecord[]
  keyReturnRecords          KeyReturnRecord[]

  @@map("rooms")
}

model RoomClaimStateEvent {
  id            String              @id @default(uuid())
  roomId        String
  entryId       String?
  fromState     InventoryClaimState
  toState       InventoryClaimState
  actorId       String
  reason        String?
  effectiveFrom DateTime            @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime            @default(now())

  room Room @relation(fields: [roomId], references: [id])

  @@map("room_claim_state_events")
}

model DeficientConditionRecord {
  id                 String                     @id @default(uuid())
  roomId             String
  category           DeficientConditionCategory
  description        String
  detectedAt         DateTime
  detectedBy         String
  resolutionDeadline DateTime
  resolvedAt         DateTime?
  resolvedBy         String?
  resolutionNotes    String?
  status             String                     @default("UNRESOLVED")

  room Room @relation(fields: [roomId], references: [id])

  @@map("deficient_condition_records")
}

// --- Holds, Quotations -------------------------------------------------

model Quotation {
  id                    String         @id @default(uuid())
  entryId               String
  segmentId             String
  versionNumber         Int            @default(1)
  referenceNumber       String
  state                 QuotationState @default(DRAFT)
  commercialTerms       Json
  totalAmount           Decimal        @db.Decimal(15, 2)
  currency              String         @default("BTN")
  validUntil            DateTime?
  sentAt                DateTime?
  sentTo                String?
  /// Link to the outbound communication that carried this quotation (S2).
  communicationRecordId String?
  supersededById        String?
  supersededAt          DateTime?
  expiredAt             DateTime?
  acceptedAt            DateTime?
  acceptedBy            String?
  folioId               String?
  /// Populated when S2 exits; versions become immutable beyond this point.
  sealedAt              DateTime?
  createdAt             DateTime       @default(now())
  createdBy             String

  entry   Entry   @relation(fields: [entryId], references: [id])
  segment Segment @relation(fields: [segmentId], references: [id])

  @@index([entryId, segmentId, state])
  @@map("quotations")
}

model SpeculativeHold {
  id            String    @id @default(uuid())
  entryId       String
  segmentId     String
  roomId        String?
  spaceId       String?
  state         HoldState @default(PLACED)
  placedAt      DateTime  @default(now())
  placedBy      String
  ttlSeconds    Int
  expiresAt     DateTime
  releasedAt    DateTime?
  releasedBy    String?
  releaseReason String?
  upgradedToId  String?
  notes         String?
  createdAt     DateTime  @default(now())

  entry   Entry   @relation(fields: [entryId], references: [id])
  segment Segment @relation(fields: [segmentId], references: [id])
  room    Room?   @relation(fields: [roomId], references: [id])
  space   Space?  @relation(fields: [spaceId], references: [id])

  @@index([entryId, segmentId, state])
  @@map("speculative_holds")
}

model CommittedHold {
  id                      String    @id @default(uuid())
  entryId                 String    @unique
  segmentId               String
  roomId                  String?
  spaceId                 String?
  roomTypeId              String
  state                   HoldState @default(PLACED)
  placedAt                DateTime  @default(now())
  placedBy                String
  confirmedAt             DateTime?
  confirmedBy             String?
  releasedAt              DateTime?
  releasedBy              String?
  releaseReason           String?
  commercialJustification String    @default("seed")
  ttlSeconds              Int       @default(86400)
  expiresAt               DateTime

  entry    Entry    @relation(fields: [entryId], references: [id])
  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@map("committed_holds")
}

// --- Reservation, Folios ------------------------------------------------

model Reservation {
  id                      String    @id @default(uuid())
  entryId                 String
  segmentId               String    @unique
  frozenRate              Decimal   @db.Decimal(15, 2)
  frozenRatePlanId        String
  frozenInclusions        Json      @default("{}")
  frozenCancellationTerms Json      @default("{}")
  frozenBillingModel      String
  frozenCheckInDate       DateTime
  frozenCheckOutDate      DateTime
  frozenGuestCount        Int
  creditCeilingIfExtended Decimal?  @db.Decimal(15, 2)
  confirmedAt             DateTime
  confirmedBy             String
  confirmationVoucherSent Boolean   @default(false)
  sealedAt                DateTime?
  createdAt               DateTime  @default(now())

  entry          Entry  @relation("EntryReservations", fields: [entryId], references: [id])
  currentForEntry Entry? @relation("EntryCurrentReservation")

  @@map("reservations")
}

model CancellationDisclosureRecord {
  id                       String   @id @default(uuid())
  entryId                  String   @unique
  segmentId                String
  noShowTreatmentStatement String
  disclosedTerms           Json     @default("{}")
  disclosedAt              DateTime @default(now())
  disclosedBy              String   @default("actor-seed-system")

  entry Entry @relation(fields: [entryId], references: [id])

  @@map("cancellation_disclosure_records")
}

model BillingModelTransitionRecord {
  id        String   @id @default(uuid())
  folioId   String
  segmentId String
  fromModel String?
  toModel   String
  createdAt DateTime @default(now())
  createdBy String

  folio   Folio   @relation(fields: [folioId], references: [id])
  segment Segment @relation(fields: [segmentId], references: [id])

  @@index([folioId, segmentId])
  @@map("billing_model_transition_records")
}

model Folio {
  id                         String     @id @default(uuid())
  entryId                    String     @unique
  state                      FolioState @default(PROVISIONAL)
  billingModel               String?
  createdAt                  DateTime   @default(now())
  createdBy                  String
  convertedToLiveAt          DateTime?
  convertedBy                String?
  closedAt                   DateTime?
  closedBy                   String?
  noShowPenaltyAmount        Decimal?   @db.Decimal(15, 2)
  noShowAdvancePaymentAmount Decimal?   @db.Decimal(15, 2)
  noShowNetPosition          Decimal?   @db.Decimal(15, 2)
  noShowFomDetermination     String?

  outstandingBalance                   Decimal @default(0) @db.Decimal(15, 2)
  advancePaymentReconciliationComplete Boolean @default(false)

  entry                   Entry                          @relation(fields: [entryId], references: [id])
  payments                PaymentRecord[]
  lines                   FolioLine[]
  disputes                DisputeRecord[]
  invoices                Invoice[]
  writeOffRecords         WriteOffRecord[]
  billingModelTransitions BillingModelTransitionRecord[]

  @@map("folios")
}

model Invoice {
  id             String       @id @default(uuid())
  folioId        String
  entryId        String
  invoiceType    InvoiceType
  state          InvoiceState @default(DRAFT)
  invoiceNumber  String?      @unique
  totalAmount    Decimal?     @db.Decimal(15, 2)
  templateKey    String?
  issuedAt       DateTime?
  issuedBy       String?
  dispatchedAt   DateTime?
  dispatchedBy   String?
  dispatchedTo   String?
  supersededById String?
  versionNumber  Int          @default(1)
  metadata       Json?
  createdAt      DateTime     @default(now())

  folio Folio @relation(fields: [folioId], references: [id])
  entry Entry @relation(fields: [entryId], references: [id])

  @@map("invoices")
}

model FolioLine {
  id                 String        @id @default(uuid())
  folioId            String
  lineType           FolioLineType
  description        String
  amount             Decimal       @db.Decimal(15, 2)
  currency           String        @default("BTN")
  chargeDate         DateTime
  stage              Stage
  postedBy           String
  nightAuditRecordId String?
  isPostStay         Boolean       @default(false)
  postedAt           DateTime      @default(now())
  createdAt          DateTime      @default(now())

  folio            Folio             @relation(fields: [folioId], references: [id])
  nightAuditRecord NightAuditRecord? @relation(fields: [nightAuditRecordId], references: [id], onUpdate: Cascade)

  @@map("folio_lines")
}

model WriteOffRecord {
  id               String   @id @default(uuid())
  folioId          String
  entryId          String
  writtenOffAmount Decimal  @db.Decimal(15, 2)
  currency         String   @default("BTN")
  reason           String
  createdAt        DateTime @default(now())
  createdBy        String

  folio Folio @relation(fields: [folioId], references: [id])
  entry Entry @relation(fields: [entryId], references: [id])

  @@map("write_off_records")
}

model PaymentRecord {
  id                    String           @id // readable PREFIX-YYYYMMDD-NNNN — allocated by allocateReadableId("PAYMENT", ...)
  folioId               String
  invoiceId             String?
  entryId               String?
  amount                Decimal          @db.Decimal(15, 2)
  currency              String           @default("BTN")
  foreignCurrencyAmount Decimal?         @db.Decimal(15, 2)
  btnEquivalent         Decimal?         @db.Decimal(15, 2)
  exchangeRate          Decimal?         @db.Decimal(10, 6)
  paymentMethod         String?          @default("CASH")
  paymentDirection      PaymentDirection
  createdAt             DateTime         @default(now())
  receivedAt            DateTime?
  recordedBy            String?
  stage                 Stage?
  notes                 String?

  folio Folio @relation(fields: [folioId], references: [id])

  @@map("payment_records")
}

model CreditExtensionCeilingRecord {
  id            String   @id // readable PREFIX-YYYYMMDD-NNNN — allocated by allocateReadableId("CREDIT_EXTENSION", ...)
  folioId       String   @unique
  entryId       String
  ceilingAmount Decimal  @db.Decimal(15, 2)
  currency      String   @default("BTN")
  approvedBy    String
  approvedAt    DateTime @default(now())
  reason        String
  createdAt     DateTime @default(now())

  @@map("credit_extension_ceiling_records")
}

// --- Operational artefacts (S5–S9) --------------------------------------

model HandoffRecord {
  id                       String       @id // readable PREFIX-YYYYMMDD-NNNN — allocated by allocateReadableId("HANDOFF", ...)
  entryId                  String
  handoffType              HandoffType
  state                    HandoffState @default(CREATED)
  fromRole                 String
  fromActorId              String
  toRole                   String
  toActorId                String?
  checklistContent         Json         @default("{}")
  deficientConditionStatus String?
  fulfilmentEvidence       Json?
  assignedAt               DateTime?
  acceptedAt               DateTime?
  acceptedBy               String?
  fulfilledAt              DateTime?
  fulfilledBy              String?
  closedAt                 DateTime?
  rejectedAt               DateTime?
  rejectedBy               String?
  rejectionReason          String?
  escalatedAt              DateTime?
  cancelledAt              DateTime?
  cancelledBy              String?
  cancelledReason          String?
  slaDeadlineAt            DateTime?
  isAutoFulfilled          Boolean      @default(false)
  createdAt                DateTime     @default(now())
  createdBy                String
  stageContext             Stage

  entry Entry @relation(fields: [entryId], references: [id])

  @@map("handoff_records")
}

model PreArrivalTask {
  id                 String             @id @default(uuid())
  entryId            String
  taskType           PreArrivalTaskType
  category           TaskCategory       @default(ADMINISTRATIVE)
  targetDate         DateTime?
  status             TaskStatus         @default(PENDING)
  assignedTo         String?
  assignedDepartment String?
  completedAt        DateTime?
  completedBy        String?
  waivedReason       String?
  waivedBy           String?
  sourceRecordType   String?
  sourceRecordId     String?
  createdAt          DateTime           @default(now())
  createdBy          String

  entry Entry @relation(fields: [entryId], references: [id])

  @@map("pre_arrival_tasks")
}

model RoomAssignment {
  id                         String    @id // readable PREFIX-YYYYMMDD-NNNN — allocated by allocateReadableId("ROOM_ASSIGNMENT", ...)
  entryId                    String
  roomId                     String
  assignedAt                 DateTime  @default(now())
  assignedBy                 String
  deficientAtAssignment      Boolean   @default(false)
  deficientConditionRecordId String?
  acknowledgementActorId     String?
  acknowledgementAt          DateTime?
  notes                      String?
  createdAt                  DateTime  @default(now())

  entry Entry @relation(fields: [entryId], references: [id])
  room  Room  @relation(fields: [roomId], references: [id])

  @@map("room_assignments")
}

model NoShowDeterminationRecord {
  id                      String   @id // readable PREFIX-YYYYMMDD-NNNN — allocated by allocateReadableId("NO_SHOW", ...)
  entryId                 String   @unique
  determinationPath       String
  fomActorId              String
  contactAttemptLog       Json
  decisionReason          String
  otaNotificationRequired Boolean  @default(false)
  otaNotificationStatus   String?
  determinedAt            DateTime @default(now())
  createdAt               DateTime @default(now())
  createdBy               String

  entry Entry @relation(fields: [entryId], references: [id])

  @@map("no_show_determination_records")
}

model RoomInspectionRecord {
  id                   String   @id // readable PREFIX-YYYYMMDD-NNNN — allocated by allocateReadableId("ROOM_INSPECTION", ...)
  entryId              String
  roomId               String
  segmentId            String
  inspectedBy          String
  inspectedAt          DateTime
  isDeferred           Boolean  @default(false)
  deficientFlagStatus  String
  deficientConditionId String?
  inspectorAssessment  String?
  damageFound          Boolean  @default(false)
  damageNotes          String?
  createdAt            DateTime @default(now())

  entry Entry @relation(fields: [entryId], references: [id])
  room  Room  @relation(fields: [roomId], references: [id])

  @@map("room_inspection_records")
}

model KeyReturnRecord {
  id                 String   @id // readable PREFIX-YYYYMMDD-NNNN — allocated by allocateReadableId("KEY_RETURN", ...)
  entryId            String
  roomId             String
  receivedBy         String
  returnedAt         DateTime
  keyCountIssued     Int
  keyCountReturned   Int
  countReconciled    Boolean
  reconciliationNote String?
  createdAt          DateTime @default(now())

  entry Entry @relation(fields: [entryId], references: [id])
  room  Room  @relation(fields: [roomId], references: [id])

  @@map("key_return_records")
}

// --- Timers, Dwell ------------------------------------------------------

model TimerRecord {
  id              String      @id @default(uuid())
  entryId         String?
  entityType      String      @default("Entry")
  entityId        String      @default("")
  timerType       String
  timerCode       String      @default("")
  stageContext    Stage?
  firesAt         DateTime    @default(now())
  dueAt           DateTime    @default(now())
  warningAt       DateTime?
  criticalAt      DateTime?
  status          TimerStatus @default(SCHEDULED)
  payload         Json?
  pgBossJobId     String?
  cancelledAt     DateTime?
  cancelledBy     String?
  cancelledReason String?
  firedAt         DateTime?
  createdAt       DateTime    @default(now())
  createdBy       String

  entry Entry? @relation(fields: [entryId], references: [id])

  @@index([timerType, status, firesAt])
  @@index([timerCode, status, dueAt])
  @@index([entityType, entityId])
  @@map("timer_records")
}

model StageDwellRecord {
  id              String         @id @default(uuid())
  entryId         String
  stage           Stage
  enteredAt       DateTime       @default(now())
  lastActiveAt    DateTime       @default(now())
  exitedAt        DateTime?
  dwellSeconds    Int?
  mode            StageDwellMode @default(ACTIVE)
  warningFiredAt  DateTime?
  criticalFiredAt DateTime?
  escalatedAt     DateTime?
  createdAt       DateTime       @default(now())

  entry Entry @relation(fields: [entryId], references: [id])

  @@index([entryId, stage])
  @@map("stage_dwell_records")
}

// --- S7+ records (kept for stage-by-stage roll-forward) ----------------

model CreditCeilingThresholdEvent {
  id                 String   @id @default(uuid())
  entryId            String
  folioId            String
  ceilingAmount      Decimal  @db.Decimal(15, 2)
  outstandingBalance Decimal  @db.Decimal(15, 2)
  thresholdPercent   Int
  createdAt          DateTime @default(now())
  createdBy          String

  @@map("credit_ceiling_threshold_events")
}

model NightAuditRecord {
  id                    String              @id // readable PREFIX-YYYYMMDD-NNNN — allocated by allocateReadableId("NIGHT_AUDIT", ...)
  operatingDate         DateTime            @unique
  runStatus             NightAuditRunStatus
  entriesProcessedCount Int                 @default(0)
  entriesNotProcessed   Json?
  createdAt             DateTime            @default(now())
  createdBy             String

  folioLines FolioLine[]
  anomalies  NightAuditAnomaly[]

  @@map("night_audit_records")
}

model NightAuditAnomaly {
  id                 String                @id @default(uuid())
  nightAuditRecordId String
  entryId            String?
  anomalyType        NightAuditAnomalyType
  description        String
  createdAt          DateTime              @default(now())
  resolvedAt         DateTime?
  resolvedBy         String?

  nightAuditRecord NightAuditRecord @relation(fields: [nightAuditRecordId], references: [id], onUpdate: Cascade)

  @@map("night_audit_anomalies")
}

model WorkOrder {
  id        String   @id // readable PREFIX-YYYYMMDD-NNNN — allocated by allocateReadableId("WORK_ORDER", ...)
  entryId   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  createdBy String

  todoItems    WorkOrderToDoItem[]
  amendments   WorkOrderAmendmentEvent[]
  consumptions WorkOrderConsumptionRecord[]

  @@map("work_orders")
}

model WorkOrderToDoItem {
  id           String              @id @default(uuid())
  workOrderId  String
  title        String
  status       WorkOrderToDoStatus @default(PENDING)
  dueAt        DateTime?
  createdAt    DateTime            @default(now())
  createdBy    String
  updatedAt    DateTime            @updatedAt
  updatedBy    String?
  cancelReason String?

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onUpdate: Cascade)

  @@map("work_order_todo_items")
}

