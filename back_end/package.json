{
  "name": "legphel-pms-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "test:s6": "npm run db:seed && npx tsx scripts/s6-acceptance-tests.ts",
    "test:s7": "npm run db:seed && npx tsx scripts/s7-acceptance-tests.ts",
    "test:s8": "npm run db:seed && npx tsx scripts/s8-acceptance-tests.ts",
    "test:s9": "npm run db:seed && npx tsx scripts/s9-acceptance-tests.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "pg-boss": "^12.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.1",
    "node-fetch": "^3.3.2",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
