# Express API (used by Next.js rewrites for /api/*)
BACKEND_URL=http://127.0.0.1:4000

# Optional: extra dev origins (comma-separated). Private LAN ranges (192.168.*, 10.*) are allowlisted by default.
# ALLOWED_DEV_ORIGINS=192.168.1.110,192.168.1.110:3001

# Dev server port (npm run dev uses 3001). Must match the port in your browser URL.
# NEXT_DEV_PORT=3001

# Default terminal for PIN authentication
NEXT_PUBLIC_DEFAULT_TERMINAL_ID=terminal-1

# Note: http://localhost:3000 and http://192.168.x.x:3000 are different browser origins.
# Log in separately on each, or pick one URL for daily dev to avoid mismatched session/UI state.
#
# LAN demo (boss on same Wi‑Fi) — copy this file to .env.local if missing:
#   npm run dev:all          (from front_end — starts API + LAN UI)
#   Boss: http://<your-ip>:3001
#   You test: http://localhost:3001/api/dev/connectivity  (must show ok: true)
# Optional: Admin PowerShell → npm run dev:firewall
